{
  "name": "@ctxlyr/typecheck",
  "version": "0.1.20",
  "description": "Token-efficient TypeScript error output for AI agents",
  "type": "module",
  "main": "bin/index.js",
  "bin": {
    "typecheck": "bin/index.js"
  },
  "files": [
    "bin"
  ],
  "scripts": {
    "typecheck": "bun ./bin/index.js",
    "build": "bun build ./src/typecheck.ts --outfile ./bin/index.js --target bun",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "keywords": [
    "typescript",
    "tsc",
    "typecheck",
    "ai",
    "agent",
    "context"
  ],
  "license": "MIT"
}
