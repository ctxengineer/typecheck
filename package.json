  },
  "keywords": [
    "typescript",
    "tsc",
    "typecheck",
    "ai",
    "agent",
    "context"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ctxlyr/typecheck.git"
  }
